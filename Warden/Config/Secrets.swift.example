//
//  Copy this file to Secrets.swift and fill in your values.
//  Find these in your Supabase dashboard under Settings > API.
//

enum Secrets {
    /// Supabase project URL — Supabase dashboard > Settings > API > Project URL
    static let supabaseURL = "https://<your-project-ref>.supabase.co"
    /// Supabase anon public key — Supabase dashboard > Settings > API > Project API keys
    static let supabaseAnonKey = "<your-anon-key>"
}
